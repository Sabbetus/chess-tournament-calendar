---
import Base from '../../layouts/Base.astro';
import TournamentListPage from '../../components/TournamentListPage.astro';
import featuredData from '../../../data/featured.json';
import tournamentsData from '../../../public/data/tournaments.json';
import metaData from '../../../public/data/meta.json';
import { getTranslations } from '../../i18n/index.ts';
import { getContinent } from '../../lib/continents.ts';
import { getCountryGroups } from '../../lib/locationGroups.ts';
import { slugifyLocation, CONTINENT_SLUGS } from '../../lib/locationSlug.ts';

export function getStaticPaths() {
  const allItems = [...(tournamentsData as any[]), ...(featuredData as any[])];
  const groups = getCountryGroups(allItems, 'en');
  return groups.map((g) => ({ params: { country: g.slug }, props: { group: g } }));
}

const lang = 'en';
const t = getTranslations(lang);
const { group } = Astro.props as { group: ReturnType<typeof getCountryGroups>[number] };
const PAGE_SIZE = 50;
const JSONLD_CAP = 100;

// The manually-curated featured tournament is rendered separately (pinned,
// same as the homepage) so it isn't silently dropped when the client-side
// list hydrates from tournaments-min.json, which only contains scraped data.
const featuredForPage = (featuredData as any[]).filter((f) => f.country === group.englishName);
const items = group.items
  .filter((item: any) => item.source !== 'manual')
  .sort((a, b) => a.startDate.localeCompare(b.startDate));
const continentSlug = CONTINENT_SLUGS[group.continentCode];
const CONTINENT_NAMES: Record<string, string> = {
  EU: t.continent_EU, AS: t.continent_AS, NA: t.continent_NA,
  SA: t.continent_SA, AF: t.continent_AF, OC: t.continent_OC,
};
const continentName = CONTINENT_NAMES[group.continentCode];

// Nav controls (country dropdown, continent tabs) are always sitewide --
// they're destinations, not filters, so they work identically here as on
// the homepage.
const allForCounts = [...(tournamentsData as any[]), ...(featuredData as any[])];
const continentCounts: Record<string, number> = {};
for (const item of allForCounts) {
  const c = getContinent(item.countryCode || '');
  if (c !== 'XX') continentCounts[c] = (continentCounts[c] || 0) + 1;
}
const continentsSorted = Object.entries(continentCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([code, count]) => ({ code, name: CONTINENT_NAMES[code] || code, count }));

const countryCounts: Record<string, number> = {};
const countrySlugs: Record<string, string> = {};
for (const item of allForCounts) {
  if (item.country && item.countryCode) {
    countryCounts[item.country] = (countryCounts[item.country] || 0) + 1;
    countrySlugs[item.country] = slugifyLocation(item.country);
  }
}
const countries = Object.keys(countryCounts).sort().map((name) => ({ value: name, label: name }));

// Month counts are scoped to this country's own tournaments, not sitewide --
// they describe what this page's month filter will actually show.
const monthCounts: Record<number, number> = {};
for (const item of [...items, ...featuredForPage]) {
  const m = new Date(item.startDate + 'T00:00:00').getMonth() + 1;
  monthCounts[m] = (monthCounts[m] || 0) + 1;
}
const MONTH_NAMES: Record<number, string> = {};
(t.months as string[]).forEach((name, i) => { if (i > 0) MONTH_NAMES[i] = name; });

const lastUpdated = new Date(metaData.lastUpdated).toLocaleString(t.date_locale, {
  day: 'numeric', month: 'short', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZone: 'UTC', timeZoneName: 'short'
});

const ogImage = new URL('og-image.png', Astro.site).href;

function toEventSchema(item: any) {
  const tcLabel = item.timeControl === 'Rapid' ? 'Rapid' : 'Classical';
  return {
    "@type": "Event",
    "name": item.name,
    "startDate": item.startDate,
    "endDate": item.endDate,
    "description": item.description
      || `${item.name}: ${tcLabel} chess tournament${item.city ? ' in ' + item.city : ''}${item.country ? ', ' + item.country : ''}.`,
    "image": ogImage,
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "eventStatus": "https://schema.org/EventScheduled",
    "location": {
      "@type": "Place",
      "name": item.city || item.country,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": item.city || undefined,
        "addressCountry": item.countryCode || undefined,
      },
    },
    "url": item.websiteUrl || item.registrationUrl || undefined,
    "organizer": item.organizer
      ? { "@type": "Organization", "name": item.organizer }
      : undefined,
  };
}

const eventSchema = {
  "@context": "https://schema.org",
  "@graph": [...featuredForPage, ...items.slice(0, JSONLD_CAP)].map(toEventSchema),
};

const initialTournaments = items.slice(0, PAGE_SIZE);
const dataUrl = `${import.meta.env.BASE_URL}data/tournaments-min.json?v=${new Date(metaData.lastUpdated).getTime()}`;

const titlePrefix = `${t.location_tournaments_in} `;
const titleSuffix = ` — ${t.site_title}`;
const maxNameLen = 69 - titlePrefix.length - titleSuffix.length;
const titleCountryName = group.displayName.length > maxNameLen
  ? group.displayName.slice(0, maxNameLen - 1).trimEnd() + '…'
  : group.displayName;
const pageTitle = `${titlePrefix}${titleCountryName}${titleSuffix}`;
const pageDesc = `${t.location_desc_prefix} ${group.displayName}: ${items.length + featuredForPage.length} ${t.tournaments_unit_nom}. ${t.footer_updated}`;
const currentPath = `country/${group.slug}`;

const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": t.site_title, "item": "https://chesstournamentcalendar.com/" },
];
if (continentSlug && continentName) {
  breadcrumbItems.push({
    "@type": "ListItem", "position": 2, "name": continentName,
    "item": `https://chesstournamentcalendar.com/continent/${continentSlug}/`,
  });
}
breadcrumbItems.push({ "@type": "ListItem", "position": breadcrumbItems.length + 1, "name": group.displayName });

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems,
};
---

<Base title={pageTitle} description={pageDesc} lang={lang} currentPath={currentPath}>
  <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="breadcrumb">
    <a href="/">{t.back_to_calendar}</a>
    {continentSlug && continentName && <>{' · '}<a href={`/continent/${continentSlug}/`}>{continentName}</a></>}
  </nav>

  <h1 class="location-heading">
    {group.countryCode && <img src={`/flags/${group.countryCode.toLowerCase()}.png`} alt="" width="28" height="21" />}
    {t.location_tournaments_in} {group.displayName}
  </h1>

  <TournamentListPage
    t={t}
    lang={lang}
    basePath=""
    featured={featuredForPage}
    initialTournaments={initialTournaments}
    totalCount={items.length}
    pageSize={PAGE_SIZE}
    countries={countries}
    countryCounts={countryCounts}
    countrySlugs={countrySlugs}
    countryLocalizedMap={{}}
    continentsSorted={continentsSorted}
    allCount={allForCounts.length}
    monthCounts={monthCounts}
    monthNames={MONTH_NAMES}
    lastUpdated={lastUpdated}
    dataUrl={dataUrl}
    renderOnLoad={false}
    lockedCountry={group.englishName}
    lockedLabel={group.displayName}
    activeContinentCode={group.continentCode}
    selectedCountryValue={group.englishName}
  />
</Base>
