---
import Base from '../layouts/Base.astro';
import TournamentCard from '../components/TournamentCard.astro';
import featuredData from '../../data/featured.json';
import tournamentsData from '../../data/tournaments.json';

const featured = featuredData;
const tournaments = tournamentsData;

// Collect unique countries for filter
const countries = [...new Set(tournaments.map((t: any) => t.country))].sort();

const lastUpdated = new Date().toLocaleString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZone: 'UTC', timeZoneName: 'short'
});
---

<Base title="Chess Tournament Calendar — Long Tournaments Worldwide">
  <div class="hero">
    <h1>Chess Tournament Calendar</h1>
    <p>Long tournaments (7+ days) from around the world &mdash; updated every 12 hours.</p>
  </div>

  <div class="filters" id="filters">
    <div class="filter-group">
      <label for="f-country">Country</label>
      <select id="f-country">
        <option value="">All countries</option>
        {countries.map((c: any) => <option value={c}>{c}</option>)}
      </select>
    </div>
    <div class="filter-group">
      <label for="f-month">Month</label>
      <select id="f-month">
        <option value="">Any month</option>
        <option value="1">January</option>
        <option value="2">February</option>
        <option value="3">March</option>
        <option value="4">April</option>
        <option value="5">May</option>
        <option value="6">June</option>
        <option value="7">July</option>
        <option value="8">August</option>
        <option value="9">September</option>
        <option value="10">October</option>
        <option value="11">November</option>
        <option value="12">December</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="f-open">Entry</label>
      <select id="f-open">
        <option value="">Any</option>
        <option value="open">Open to all</option>
        <option value="rated">Rating required</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="f-search">Search</label>
      <input id="f-search" type="text" placeholder="Tournament name…" />
    </div>
    <button class="filter-reset" id="filter-reset">Reset</button>
  </div>

  <!-- Featured -->
  <div class="section-label featured">★ Featured Tournaments</div>
  <div class="tournament-grid">
    {featured.map((t: any) => <TournamentCard tournament={t} featured={true} />)}
  </div>

  <!-- Main listing -->
  <div class="section-label">Upcoming Tournaments</div>
  <div class="count-bar" id="count-bar">
    Showing <span id="visible-count">{tournaments.length}</span> of <span>{tournaments.length}</span> tournaments
  </div>

  {tournaments.length === 0 ? (
    <div class="empty-state">
      <span class="icon">♟</span>
      <h3>No tournaments yet</h3>
      <p>The scraper hasn't run yet, or no upcoming long tournaments were found. Check back soon.</p>
    </div>
  ) : (
    <div class="tournament-grid" id="tournament-grid">
      {tournaments.map((t: any) => <TournamentCard tournament={t} />)}
    </div>
  )}

  <div class="empty-state" id="no-results" style="display:none;">
    <span class="icon">🔍</span>
    <h3>No matches</h3>
    <p>Try adjusting your filters.</p>
  </div>

  <p style="font-size:0.75rem;color:var(--text-dim);margin-top:2rem;">
    Last updated: {lastUpdated}
  </p>
</Base>

<script>
  const grid = document.getElementById('tournament-grid');
  const noResults = document.getElementById('no-results');
  const countEl = document.getElementById('visible-count');
  const cards = grid ? Array.from(grid.querySelectorAll<HTMLElement>('.card')) : [];

  const fCountry = document.getElementById('f-country') as HTMLSelectElement;
  const fMonth   = document.getElementById('f-month') as HTMLSelectElement;
  const fOpen    = document.getElementById('f-open') as HTMLSelectElement;
  const fSearch  = document.getElementById('f-search') as HTMLInputElement;
  const resetBtn = document.getElementById('filter-reset');

  function applyFilters() {
    const country = fCountry.value;
    const month   = fMonth.value;
    const open    = fOpen.value;
    const search  = fSearch.value.toLowerCase().trim();

    let visible = 0;
    cards.forEach(card => {
      const matchCountry = !country || card.dataset.country === country;
      const matchMonth   = !month || new Date(card.dataset.start + 'T00:00:00').getMonth() + 1 === parseInt(month);
      const matchOpen    = !open  || (open === 'open' ? card.dataset.open === 'true' : card.dataset.open === 'false');
      const matchSearch  = !search || card.textContent!.toLowerCase().includes(search);
      const show = matchCountry && matchMonth && matchOpen && matchSearch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (countEl) countEl.textContent = String(visible);
    if (noResults) noResults.style.display = visible === 0 && cards.length > 0 ? 'block' : 'none';
    if (grid) grid.style.display = visible === 0 ? 'none' : '';
  }

  [fCountry, fMonth, fOpen].forEach(el => el?.addEventListener('change', applyFilters));
  fSearch?.addEventListener('input', applyFilters);
  resetBtn?.addEventListener('click', () => {
    fCountry.value = '';
    fMonth.value   = '';
    fOpen.value    = '';
    fSearch.value  = '';
    applyFilters();
  });
</script>
