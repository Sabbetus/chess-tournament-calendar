---
import Base from '../layouts/Base.astro';
import TournamentCard from '../components/TournamentCard.astro';
import featuredData from '../../data/featured.json';
import tournamentsData from '../../public/data/tournaments.json';
import metaData from '../../public/data/meta.json';
import { getTranslations } from '../i18n/index.ts';
import { getContinent } from '../lib/continents.ts';

const lang = 'en';
const t = getTranslations(lang);

const featured = featuredData;
const tournaments = tournamentsData as any[];
const PAGE_SIZE = 50;
const JSONLD_CAP = 200;

const CONTINENT_NAMES: Record<string, string> = {
  EU: t.continent_EU, AS: t.continent_AS, NA: t.continent_NA,
  SA: t.continent_SA, AF: t.continent_AF, OC: t.continent_OC,
};

const allForCounts = [...tournaments, ...featured];
const continentCounts: Record<string, number> = {};
for (const item of allForCounts) {
  const c = getContinent(item.countryCode || '');
  if (c !== 'XX') continentCounts[c] = (continentCounts[c] || 0) + 1;
}
const continentsSorted = Object.entries(continentCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([code, count]) => ({ code, name: CONTINENT_NAMES[code] || code, count }));

const countryCounts: Record<string, number> = {};
for (const item of allForCounts) {
  if (item.country) countryCounts[item.country] = (countryCounts[item.country] || 0) + 1;
}
const countries = Object.keys(countryCounts).sort();

const monthCounts: Record<number, number> = {};
for (const item of allForCounts) {
  const m = new Date(item.startDate + 'T00:00:00').getMonth() + 1;
  monthCounts[m] = (monthCounts[m] || 0) + 1;
}
const MONTH_NAMES: Record<number, string> = {};
(t.months as string[]).forEach((name, i) => { if (i > 0) MONTH_NAMES[i] = name; });

const lastUpdated = new Date(metaData.lastUpdated).toLocaleString(t.date_locale, {
  day: 'numeric', month: 'short', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZone: 'UTC', timeZoneName: 'short'
});

const ogImage = new URL('og-image.png', Astro.site).href;

function toEventSchema(item: any) {
  const tcLabel = item.timeControl === 'Rapid' ? 'Rapid' : 'Classical';
  return {
    "@type": "Event",
    "name": item.name,
    "startDate": item.startDate,
    "endDate": item.endDate,
    "description": item.description
      || `${item.name}: ${tcLabel} chess tournament${item.city ? ' in ' + item.city : ''}${item.country ? ', ' + item.country : ''}.`,
    "image": ogImage,
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "eventStatus": "https://schema.org/EventScheduled",
    "location": {
      "@type": "Place",
      "name": item.city || item.country,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": item.city || undefined,
        "addressCountry": item.countryCode || undefined,
      },
    },
    "url": item.websiteUrl || item.registrationUrl || undefined,
    "organizer": item.organizer
      ? { "@type": "Organization", "name": item.organizer }
      : undefined,
  };
}

const eventSchema = {
  "@context": "https://schema.org",
  "@graph": [...featured, ...tournaments.slice(0, JSONLD_CAP)].map(toEventSchema),
};

const initialTournaments = tournaments.slice(0, PAGE_SIZE);
// Cache-bust the feed with the build's data version so the client-rendered
// list can't show a stale CDN/browser copy that's out of sync with the SSR
// timestamp. The token only changes on a new deploy, so caching still works.
const dataUrl = `${import.meta.env.BASE_URL}data/tournaments-min.json?v=${new Date(metaData.lastUpdated).getTime()}`;
const basePath = lang === 'en' ? '' : lang;

const listConfig = {
  dataUrl,
  pageSize: PAGE_SIZE,
  basePath,
  tDays: t.days,
  tClassical: t.filter_classical,
  tRapid: t.filter_rapid,
  tMonths: t.months,
  dateLocale: t.date_locale,
  tCountries: {},
  renderOnLoad: false,
};
---

<Base title={`${t.site_title} — Chess Tournaments Worldwide`} description={t.site_description} lang={lang} currentPath="">
  <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

  <p class="intro">{t.intro}</p>

  <div class="filters" id="filters">
    <div class="filter-group">
      <label for="f-country">{t.filter_country}</label>
      <select id="f-country">
        <option value="">{t.filter_all_countries}</option>
        {countries.map((c: any) => <option value={c}>{c} ({countryCounts[c]})</option>)}
      </select>
    </div>
    <div class="filter-group">
      <label for="f-month">{t.filter_month}</label>
      <select id="f-month">
        <option value="">{t.filter_any_month}</option>
        {Object.entries(MONTH_NAMES).map(([num, name]) => monthCounts[Number(num)] ? (
          <option value={num}>{name} ({monthCounts[Number(num)]})</option>
        ) : null)}
      </select>
    </div>
    <div class="filter-group">
      <label>{t.filter_time_control}</label>
      <div class="filter-btn-group" id="f-tc">
        <button class="filter-btn active" data-value="">{t.filter_any}</button>
        <button class="filter-btn" data-value="Classical">{t.filter_classical}</button>
        <button class="filter-btn" data-value="Rapid">{t.filter_rapid}</button>
      </div>
    </div>
    <div class="filter-group">
      <label>{t.filter_duration}</label>
      <div class="filter-btn-group" id="f-duration">
        <button class="filter-btn active" data-value="">{t.filter_any}</button>
        <button class="filter-btn" data-value="long">{t.filter_7plus}</button>
        <button class="filter-btn" data-value="short">{t.filter_under7}</button>
      </div>
    </div>
    <div class="filter-group">
      <label for="f-search">{t.filter_search}</label>
      <input id="f-search" type="text" placeholder={t.filter_search_placeholder} />
    </div>
    <div class="filter-group sort-mobile">
      <label for="m-sort">{t.sort_label}</label>
      <select id="m-sort">
        <option value="date-asc">{t.sort_label}</option>
        <option value="duration-desc">{t.sort_duration_desc}</option>
        <option value="duration-asc">{t.sort_duration_asc}</option>
        <option value="players-desc">{t.sort_players_desc}</option>
        <option value="players-asc">{t.sort_players_asc}</option>
      </select>
    </div>
    <button class="filter-reset" id="filter-reset">{t.filter_reset}</button>
  </div>

  <!-- Continent tabs -->
  <div class="continent-tabs" id="continent-tabs">
    <button class="ctab active" data-continent="">{t.continent_all} <span class="ctab-count" id="ctab-count-all">{allForCounts.length}</span></button>
    {continentsSorted.map(c => (
      <button class="ctab" data-continent={c.code}>
        {c.name} <span class="ctab-count" id={`ctab-count-${c.code}`}>{c.count}</span>
      </button>
    ))}
  </div>

  <!-- Column headers -->
  <div class="tlist-header">
    <span class="th-name">{t.col_tournament}</span>
    <span class="th-tc th-sortable" data-sort="tc" role="button" tabindex="0">{t.col_type} <span class="sort-icon"></span></span>
    <span class="th-dates th-sortable" data-sort="date" role="button" tabindex="0">{t.col_dates} <span class="sort-icon"></span></span>
    <span class="th-location">{t.col_location}</span>
    <span class="th-duration th-sortable" data-sort="duration" role="button" tabindex="0">{t.col_duration} <span class="sort-icon"></span></span>
    <span class="th-players th-sortable" data-sort="players" role="button" tabindex="0">{t.col_players} <span class="sort-icon"></span></span>
  </div>

  <!-- Combined list: featured first, then regular (initial page server-rendered, rest loaded client-side) -->
  <ul class="tournament-list" id="tournament-list">
    {featured.map((item: any) => <TournamentCard tournament={item} featured={true} classicalLabel={t.filter_classical} rapidLabel={t.filter_rapid} dateLocale={t.date_locale} daysLabel={t.days} />)}
    {initialTournaments.length > 0
      ? (() => {
          let lastMonth = '';
          return initialTournaments.flatMap((item: any) => {
            const d = new Date(item.startDate + 'T00:00:00');
            const monthKey = `${d.getFullYear()}-${d.getMonth()}`;
            const monthLabel = d.toLocaleDateString(t.date_locale, { month: 'long', year: 'numeric' });
            const sep = monthKey !== lastMonth
              ? <li class="month-separator"><span class="month-separator-label">{monthLabel}</span></li>
              : null;
            lastMonth = monthKey;
            return sep ? [sep, <TournamentCard tournament={item} classicalLabel={t.filter_classical} rapidLabel={t.filter_rapid} dateLocale={t.date_locale} daysLabel={t.days} />] : [<TournamentCard tournament={item} classicalLabel={t.filter_classical} rapidLabel={t.filter_rapid} dateLocale={t.date_locale} daysLabel={t.days} />];
          });
        })()
      : (
        <li class="empty-state">
          <span class="icon">♟</span>
          <h3>{t.empty_title}</h3>
          <p>{t.empty_body}</p>
        </li>
      )
    }
  </ul>

  <button class="load-more" id="load-more" style={tournaments.length <= PAGE_SIZE ? 'display:none' : ''}>
    {t.load_more}
  </button>

  <div class="count-bar">
    {t.showing} <span id="visible-count">{Math.min(PAGE_SIZE, tournaments.length)}</span> {t.of} <span id="total-count">{tournaments.length}</span> {t.tournaments_unit}
    &nbsp;·&nbsp; {t.last_updated}: {lastUpdated}
  </div>

  <div class="empty-state" id="no-results" style="display:none;">
    <span class="icon">🔍</span>
    <h3>{t.no_matches}</h3>
    <p id="no-results-summary">{t.adjust_filters}</p>
    <button id="no-results-reset" class="btn-secondary">{t.filter_reset}</button>
  </div>

  <div id="hover-tooltip"></div>
</Base>


<script type="application/json" id="list-config" set:html={JSON.stringify(listConfig)}></script>

<script>
  import { initTournamentList } from '../scripts/tournamentList.ts';
  const cfg = JSON.parse(document.getElementById('list-config').textContent);
  initTournamentList(cfg);
</script>
