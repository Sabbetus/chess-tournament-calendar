---
export interface Tournament {
  id: string;
  name: string;
  startDate: string;
  endDate: string;
  city: string;
  country: string;
  countryCode?: string;
  rounds: number | null;
  timeControl?: string;
  playersRegistered: number | null;
  prizePool: number | null;
  currency?: string;
  ratingRequirement: number | null;
  open: boolean;
  registrationOpen: boolean;
  registrationUrl: string | null;
  websiteUrl: string | null;
  description?: string | null;
  source: string;
}

export interface Props {
  tournament: Tournament;
  featured?: boolean;
}

const { tournament: t, featured = false } = Astro.props;

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

function formatDateRange(start: string, end: string) {
  const s = new Date(start + 'T00:00:00');
  const e = new Date(end + 'T00:00:00');
  const sStr = s.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
  const eStr = e.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  return `${sStr} – ${eStr}`;
}

function durationDays(start: string, end: string) {
  const s = new Date(start + 'T00:00:00');
  const e = new Date(end + 'T00:00:00');
  return Math.round((e.getTime() - s.getTime()) / (1000 * 60 * 60 * 24)) + 1;
}

function formatPrize(amount: number | null, currency: string | undefined) {
  if (!amount) return null;
  const sym = currency === 'EUR' ? '€' : currency === 'USD' ? '$' : (currency ?? '');
  return `${sym}${amount.toLocaleString()}`;
}

const dateRange = formatDateRange(t.startDate, t.endDate);
const days = durationDays(t.startDate, t.endDate);
const prize = formatPrize(t.prizePool, t.currency);
const link = t.registrationUrl || t.websiteUrl;
const flagUrl = t.countryCode
  ? `https://flagcdn.com/20x15/${t.countryCode.toLowerCase()}.png`
  : null;
---

<article class={`card${featured ? ' featured' : ''}`} data-country={t.country} data-open={t.open} data-start={t.startDate}>
  <div class="card-header">
    <h3 class="card-name">{t.name}</h3>
    <div style="display:flex;gap:0.35rem;flex-wrap:wrap;justify-content:flex-end;">
      {featured && <span class="badge badge-featured">★ Featured</span>}
      {t.open
        ? <span class="badge badge-open">Open</span>
        : <span class="badge badge-rated">{t.ratingRequirement ? `≥${t.ratingRequirement}` : 'Rated'}</span>
      }
    </div>
  </div>

  <div class="card-meta">
    <div class="meta-item" style="grid-column: 1 / -1;">
      <span class="meta-label">Dates</span>
      <span class="meta-value accent">{dateRange}</span>
    </div>

    <div class="meta-item">
      <span class="meta-label">Location</span>
      <span class="meta-value">
        {flagUrl && <img src={flagUrl} alt={t.country} width="16" height="12" style="display:inline;vertical-align:middle;margin-right:4px;border-radius:2px;" />}
        {t.city}, {t.country}
      </span>
    </div>

    <div class="meta-item">
      <span class="meta-label">Duration</span>
      <span class="meta-value">{days} days{t.rounds ? ` · ${t.rounds} rounds` : ''}</span>
    </div>

    <div class="meta-item">
      <span class="meta-label">Players</span>
      <span class={`meta-value${t.playersRegistered === null ? ' muted' : ''}`}>
        {t.playersRegistered !== null ? `${t.playersRegistered.toLocaleString()} registered` : '—'}
      </span>
    </div>

    <div class="meta-item">
      <span class="meta-label">Prize Pool</span>
      <span class={`meta-value${!prize ? ' muted' : ''}`}>
        {prize ?? '—'}
      </span>
    </div>
  </div>

  {t.description && (
    <p style="font-size:0.8rem;color:var(--text-muted);margin-top:-0.25rem;">{t.description}</p>
  )}

  <div class="card-footer">
    {link
      ? <a href={link} class="card-link" target="_blank" rel="noopener">
          {t.registrationOpen ? 'Register →' : 'More info →'}
        </a>
      : <span />
    }
    <span class={`reg-status${t.registrationOpen ? ' open' : ''}`}>
      {t.registrationOpen ? '● Registration open' : 'Registration not yet open'}
    </span>
  </div>
</article>
