---
export interface Tournament {
  id: string;
  name: string;
  startDate: string;
  endDate: string;
  city: string;
  country: string;
  countryCode?: string;
  rounds: number | null;
  timeControl?: string;
  playersRegistered: number | null;
  playersTrend?: number | null;
  prizePool: number | null;
  currency?: string;
  ratingRequirement: number | null;
  open: boolean;
  registrationOpen: boolean;
  registrationUrl: string | null;
  websiteUrl: string | null;
  description?: string | null;
  source: string;
}

export interface Props {
  tournament: Tournament;
  featured?: boolean;
  classicalLabel?: string;
  rapidLabel?: string;
  countryLabel?: string;
  dateLocale?: string;
  daysLabel?: string;
  trendTooltip?: string;
}

const { tournament: t, featured = false, classicalLabel = 'Classical', rapidLabel = 'Rapid', countryLabel = t.country, dateLocale = 'en-GB', daysLabel = 'days', trendTooltip = '' } = Astro.props;
const base = import.meta.env.BASE_URL;

function formatDateRange(start: string, end: string) {
  const s = new Date(start + 'T00:00:00');
  const e = new Date(end + 'T00:00:00');
  const sStr = s.toLocaleDateString(dateLocale, { day: 'numeric', month: 'short' });
  const eStr = e.toLocaleDateString(dateLocale, { day: 'numeric', month: 'short', year: 'numeric' });
  return `${sStr} – ${eStr}`;
}

function durationDays(start: string, end: string) {
  const s = new Date(start + 'T00:00:00');
  const e = new Date(end + 'T00:00:00');
  return Math.round((e.getTime() - s.getTime()) / (1000 * 60 * 60 * 24)) + 1;
}


const dateRange = formatDateRange(t.startDate, t.endDate);
const days = durationDays(t.startDate, t.endDate);
// Some organizers put a full street address in the city field; only the
// first comma-separated segment is meaningful as a "city" label. Matches
// the same trim applied to the client-fetched slim feed, so rows look
// identical whether they were server-rendered or loaded client-side.
const city = t.city ? t.city.split(',')[0].trim() : t.city;
const detailUrl = t.slug ? `${base}tournament/${t.slug}/` : null;
const link = detailUrl || t.registrationUrl || t.websiteUrl;
const flagUrl = t.countryCode
  ? `${base}flags/${t.countryCode.toLowerCase()}.png`
  : null;
const tcLabel = t.timeControl === 'Rapid' ? rapidLabel : classicalLabel;
const tcClass = t.timeControl === 'Rapid' ? 'badge-rapid' : 'badge-classical';
const trend = typeof t.playersTrend === 'number' && t.playersTrend !== 0 ? t.playersTrend : null;
---

<li class={`trow${featured ? ' trow-featured' : ''}${t.description ? ' has-desc' : ''}`} data-country={t.country} data-open={t.open} data-start={t.startDate} data-duration={days} data-players={t.playersRegistered ?? -1}>
  <div class="trow-main">
    <span class="trow-name">
      {featured && <span class="trow-star" title="Featured">★</span>}
      <span class="trow-name-text">
        {link
          ? <a href={link} {...(!detailUrl ? { target: "_blank", rel: "noopener" } : {})}>{t.name}</a>
          : t.name
        }
      </span>
    </span>
    <span class="trow-tc"><span class={`tc-badge ${tcClass}`}>{tcLabel}</span></span>
    <span class="trow-dates">{dateRange}</span>
    <span class="trow-location" data-tooltip={`${city}, ${countryLabel}`}>
      {flagUrl && <img src={flagUrl} alt="" width="14" height="11" loading="lazy" />}
      {city}, {countryLabel}
    </span>
    <span class="trow-duration">{days} {daysLabel}</span>
    <span class="trow-players">
      {t.playersRegistered !== null ? t.playersRegistered : '—'}
      {trend !== null && (
        <span class={`trend ${trend > 0 ? 'trend-up' : 'trend-down'}`} data-tooltip={trendTooltip}>
          (<span class="trend-arrow">{trend > 0 ? '▲' : '▼'}</span> {Math.abs(trend)})
        </span>
      )}
    </span>
  </div>
  <div class="trow-meta">
    <span class="trow-dates">{dateRange}</span>
    <span class="trow-location">
      {flagUrl && <img src={flagUrl} alt="" width="14" height="11" loading="lazy" />}
      <span class="trow-location-city">{city}, </span><span class="trow-location-country">{countryLabel}</span>
    </span>
    <span class="trow-info">
      <span>{days} {daysLabel}</span>
      <span class={`tc-badge ${tcClass}`}>{tcLabel}</span>
      {t.playersRegistered !== null && (
        <span>
          👥 {t.playersRegistered}
          {trend !== null && (
            <span class={`trend ${trend > 0 ? 'trend-up' : 'trend-down'}`} data-tooltip={trendTooltip}>
              (<span class="trend-arrow">{trend > 0 ? '▲' : '▼'}</span> {Math.abs(trend)})
            </span>
          )}
        </span>
      )}
    </span>
  </div>
  {t.description && (
    <div class="trow-desc">{t.description}</div>
  )}
</li>
