---
export interface Tournament {
  id: string;
  name: string;
  startDate: string;
  endDate: string;
  city: string;
  country: string;
  countryCode?: string;
  rounds: number | null;
  timeControl?: string;
  playersRegistered: number | null;
  prizePool: number | null;
  currency?: string;
  ratingRequirement: number | null;
  open: boolean;
  registrationOpen: boolean;
  registrationUrl: string | null;
  websiteUrl: string | null;
  description?: string | null;
  source: string;
}

export interface Props {
  tournament: Tournament;
  featured?: boolean;
  classicalLabel?: string;
  rapidLabel?: string;
  countryLabel?: string;
}

const { tournament: t, featured = false, classicalLabel = 'Classical', rapidLabel = 'Rapid', countryLabel = t.country } = Astro.props;
const base = import.meta.env.BASE_URL;

function formatDateRange(start: string, end: string) {
  const s = new Date(start + 'T00:00:00');
  const e = new Date(end + 'T00:00:00');
  const sStr = s.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
  const eStr = e.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  return `${sStr} – ${eStr}`;
}

function durationDays(start: string, end: string) {
  const s = new Date(start + 'T00:00:00');
  const e = new Date(end + 'T00:00:00');
  return Math.round((e.getTime() - s.getTime()) / (1000 * 60 * 60 * 24)) + 1;
}


const dateRange = formatDateRange(t.startDate, t.endDate);
const days = durationDays(t.startDate, t.endDate);
const detailUrl = t.slug ? `${base}tournament/${t.slug}` : null;
const link = detailUrl || t.registrationUrl || t.websiteUrl;
const flagUrl = t.countryCode
  ? `https://flagcdn.com/20x15/${t.countryCode.toLowerCase()}.png`
  : null;
const tcLabel = t.timeControl === 'Rapid' ? rapidLabel : classicalLabel;
const tcClass = t.timeControl === 'Rapid' ? 'badge-rapid' : 'badge-classical';
---

<li class={`trow${featured ? ' trow-featured' : ''}${t.description ? ' has-desc' : ''}`} data-country={t.country} data-open={t.open} data-start={t.startDate} data-duration={days} data-players={t.playersRegistered ?? -1}>
  <div class="trow-main">
    <span class="trow-name">
      {featured && <span class="trow-star" title="Featured">★</span>}
      <span class="trow-name-text">
        {link
          ? <a href={link} {...(!detailUrl ? { target: "_blank", rel: "noopener" } : {})}>{t.name}</a>
          : t.name
        }
      </span>
    </span>
    <span class="trow-tc"><span class={`tc-badge ${tcClass}`}>{tcLabel}</span></span>
    <span class="trow-dates">{dateRange}</span>
    <span class="trow-location" data-tooltip={`${t.city}, ${countryLabel}`}>
      {flagUrl && <img src={flagUrl} alt={t.country} width="14" height="11" loading="lazy" />}
      {t.city}, {countryLabel}
    </span>
    <span class="trow-duration">{days} days</span>
    <span class="trow-players">{t.playersRegistered !== null ? t.playersRegistered : '—'}</span>
  </div>
  <div class="trow-meta">
    <span class="trow-dates">{dateRange}</span>
    <span class="trow-location">
      {flagUrl && <img src={flagUrl} alt={t.country} width="14" height="11" loading="lazy" />}
      <span class="trow-location-city">{t.city}, </span><span class="trow-location-country">{countryLabel}</span>
    </span>
    <span class="trow-info">
      <span>{days} days</span>
      <span class={`tc-badge ${tcClass}`}>{tcLabel}</span>
      {t.playersRegistered !== null && <span>👥 {t.playersRegistered}</span>}
    </span>
  </div>
  {t.description && (
    <div class="trow-desc">{t.description}</div>
  )}
</li>
