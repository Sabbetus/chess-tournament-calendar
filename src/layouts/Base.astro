---
import '../styles/global.css';
export interface Props {
  title?: string;
}
const { title = 'Chess Tournament Calendar' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Find long chess tournaments worldwide. Updated twice daily from chess-results.com." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

</head>
<body>
  <header>
    <div class="header-inner">
      <a href={base} class="logo">
        <span class="logo-icon">♟</span>
        <span class="logo-text">Chess Tournament Calendar</span>
      </a>
      <nav>
        <a href={base}>Tournaments</a>
        <a href="https://nordicchess.fi" target="_blank" rel="noopener">Nordic Chess Festival</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-inner">
      <p>Tournament data sourced from <a href="https://chess-results.com" target="_blank" rel="noopener">chess-results.com</a>. Updated every 12 hours.</p>
      <p>Built with ♟ for chess players. <a href="https://nordicchess.fi" target="_blank" rel="noopener">Nordic Chess Festival</a></p>
    </div>
  </footer>
</body>
</html>
