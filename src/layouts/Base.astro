---
import '../styles/global.css';
import { SUPPORTED_LANGS, langUrl, getTranslations } from '../i18n/index.ts';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  currentPath?: string;
  noindex?: boolean;
}
const {
  title = 'Chess Tournament Calendar',
  description = 'Find classical and rapid chess tournaments worldwide. Updated every 12 hours.',
  lang = 'en',
  currentPath = '',
  noindex = false,
} = Astro.props;
const t = getTranslations(lang);
const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('og-image.png', Astro.site);

const langLabels: Record<string, string> = {
  en: 'EN', es: 'ES', pt: 'PT', de: 'DE', cs: 'CS', fi: 'FI',
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,follow" />}
  <link rel="canonical" href={canonicalURL} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

  <!-- hreflang alternates -->
  {SUPPORTED_LANGS.map(l => (
    <link rel="alternate" hreflang={l} href={`https://chesstournamentcalendar.com${langUrl(l, currentPath)}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`https://chesstournamentcalendar.com${currentPath ? `/${currentPath}` : '/'}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Chess Tournament Calendar" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Chess Tournament Calendar",
    "url": "https://chesstournamentcalendar.com"
  })} />

  <!-- Auto-redirect to preferred language (English pages only) -->
  {lang === 'en' && (
    <script define:vars={{ currentPath }}>
      (function() {
        var saved = localStorage.getItem('ctc-lang');
        if (saved && saved !== 'en') {
          var path = currentPath ? '/' + saved + '/' + currentPath : '/' + saved + '/';
          window.location.replace(path);
          return;
        }
        if (saved) return;
        var map = { es:'es', pt:'pt', de:'de', cs:'cs', sk:'cs', fi:'fi' };
        var langs = (navigator.languages || [navigator.language]);
        for (var i = 0; i < langs.length; i++) {
          var code = langs[i].split('-')[0].toLowerCase();
          if (map[code]) {
            localStorage.setItem('ctc-lang', map[code]);
            var dest = currentPath ? '/' + map[code] + '/' + currentPath : '/' + map[code] + '/';
            window.location.replace(dest);
            return;
          }
        }
        localStorage.setItem('ctc-lang', 'en');
      })();
    </script>
  )}

  <!-- Google Analytics — immediate on desktop, deferred on mobile to avoid blocking render -->
  <script>
    (function() {
      var loaded = false;
      function loadGA() {
        if (loaded) return;
        loaded = true;
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-PME2NXTXQR';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        window.gtag = function(){ window.dataLayer.push(arguments); };
        window.gtag('js', new Date());
        window.gtag('config', 'G-PME2NXTXQR');
      }
      if (window.innerWidth >= 768) {
        loadGA();
      } else {
        setTimeout(loadGA, 3000);
        ['click','scroll','keydown','touchstart'].forEach(function(e) {
          document.addEventListener(e, loadGA, {once: true, passive: true});
        });
      }
    })();
  </script>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href={lang === 'en' ? base : `${base}${lang}/`} class="logo">
        <div class="logo-icon-box">♟</div>
        {currentPath === ''
          ? <h1 class="logo-title">Chess Tournament Calendar</h1>
          : <span class="logo-title">Chess Tournament Calendar</span>}
        <span class="logo-sep">·</span>
        <span class="logo-sub">Chess tournaments worldwide</span>
      </a>
      <nav class="lang-switcher" aria-label="Language">
        {SUPPORTED_LANGS.map(l => (
          <a
            href={langUrl(l, currentPath)}
            class={`lang-link${l === lang ? ' lang-active' : ''}`}
            onclick={`localStorage.setItem('ctc-lang','${l}')`}
            aria-current={l === lang ? 'true' : undefined}
          >{langLabels[l]}</a>
        ))}
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-inner">
      <a href={lang === 'en' ? `${base}contact` : `${base}${lang}/contact`} class="footer-contact">{t.footer_contact}</a>
      <p>{t.footer_data_source} <a href="https://chess-results.com" target="_blank" rel="noopener">chess-results.com</a>. {t.footer_updated}</p>
    </div>
  </footer>
</body>
</html>
