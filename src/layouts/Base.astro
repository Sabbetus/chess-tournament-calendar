---
import '../styles/global.css';
export interface Props {
  title?: string;
}
const { title = 'Chess Tournament Calendar' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Find long classical chess tournaments worldwide. Updated twice daily." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <div class="header-inner">
      <a href={base} class="logo">
        <div class="logo-icon-box">♟</div>
        <span class="logo-title">Chess Tournament Calendar</span>
        <span class="logo-sep">·</span>
        <span class="logo-sub">Long classical tournaments worldwide</span>
      </a>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-inner">
      <p>Tournament data sourced from <a href="https://chess-results.com" target="_blank" rel="noopener">chess-results.com</a>. Updated every 12 hours.</p>
    </div>
  </footer>
</body>
</html>
