---
import '../styles/global.css';
export interface Props {
  title?: string;
}
const { title = 'Chess Tournament Calendar' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Find long chess tournaments worldwide. Updated twice daily." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
</head>
<body>
  <header>
    <div class="header-board" aria-hidden="true">
      {Array.from({length: 32}).map((_, i) => <span class="sq" />)}
    </div>
    <div class="header-inner">
      <a href={base} class="logo">
        <span class="logo-icon">♟</span>
        <div class="logo-text-group">
          <span class="logo-title">Chess Tournament Calendar</span>
          <span class="logo-sub">Long tournaments worldwide</span>
        </div>
      </a>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-inner">
      <p>Tournament data sourced from <a href="https://chess-results.com" target="_blank" rel="noopener">chess-results.com</a>. Updated every 12 hours.</p>
    </div>
  </footer>
</body>
</html>
